{
  "$schema": "../_schema/manifest.schema.json",
  "id": "district_issue_snapshot",
  "version": 1,
  "model": "sonnet",
  "max_turns": 60,
  "timeout_seconds": 1200,
  "input_schema": {
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "DistrictIssueSnapshotInput",
    "type": "object",
    "additionalProperties": false,
    "required": ["state", "city", "l2DistrictType", "l2DistrictName", "issueKeyword"],
    "properties": {
      "state": {
        "type": "string",
        "pattern": "^[A-Z]{2}$",
        "description": "2-letter state code (e.g. NC)."
      },
      "city": {
        "type": "string",
        "minLength": 1,
        "description": "Full city name (e.g. Fayetteville)."
      },
      "l2DistrictType": {
        "type": "string",
        "minLength": 1,
        "description": "L2 voter file column name for district (e.g. City_Ward)."
      },
      "l2DistrictName": {
        "type": "string",
        "minLength": 1,
        "description": "L2 district value to match (e.g. FAYETTEVILLE CITY WARD 2)."
      },
      "issueKeyword": {
        "type": "string",
        "minLength": 1,
        "maxLength": 120,
        "description": "Short issue phrase to match against hs_* columns (e.g. 'affordable housing', 'minimum wage')."
      }
    }
  },
  "output_schema": {
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "DistrictIssueSnapshotOutput",
    "type": "object",
    "additionalProperties": false,
    "required": [
      "state",
      "city",
      "l2_district_type",
      "l2_district_name",
      "issue_keyword",
      "matched_hs_column",
      "issue_label",
      "total_active_voters",
      "aligned_voter_count",
      "aligned_voter_percentage",
      "news",
      "generated_at"
    ],
    "properties": {
      "state": {
        "type": "string",
        "pattern": "^[A-Z]{2}$"
      },
      "city": {
        "type": "string",
        "minLength": 1
      },
      "l2_district_type": {
        "type": "string",
        "minLength": 1
      },
      "l2_district_name": {
        "type": "string",
        "minLength": 1
      },
      "issue_keyword": {
        "type": "string",
        "minLength": 1
      },
      "matched_hs_column": {
        "type": ["string", "null"],
        "pattern": "^hs_[a-z0-9_]+$"
      },
      "issue_label": {
        "type": "string",
        "minLength": 1,
        "maxLength": 200
      },
      "total_active_voters": {
        "type": "integer",
        "minimum": 0
      },
      "aligned_voter_count": {
        "type": ["integer", "null"],
        "minimum": 0
      },
      "aligned_voter_percentage": {
        "type": ["number", "null"],
        "minimum": 0,
        "maximum": 100
      },
      "news": {
        "type": "object",
        "additionalProperties": false,
        "required": ["source_name", "url", "title", "summary", "published_date"],
        "properties": {
          "source_name": {
            "type": "string",
            "minLength": 1
          },
          "url": {
            "type": "string",
            "pattern": "^https?://"
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "summary": {
            "type": "string",
            "minLength": 20,
            "maxLength": 1000
          },
          "published_date": {
            "type": "string",
            "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
          }
        }
      },
      "generated_at": {
        "type": "string",
        "format": "date-time"
      }
    }
  },
  "scope": {
    "allowed_tables": [
      "goodparty_data_catalog.dbt.int__l2_nationwide_uniform_w_haystaq"
    ],
    "max_rows": 1000
  }
}
