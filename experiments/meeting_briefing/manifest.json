{
  "$schema": "../_schema/manifest.schema.json",
  "id": "meeting_briefing",
  "version": 1,
  "model": "sonnet",
  "max_turns": 180,
  "timeout_seconds": 1800,
  "input_schema": {
    "$schema": "http://json-schema.org/draft-07/schema#",
    "type": "object",
    "additionalProperties": false,
    "required": ["state", "city", "office"],
    "properties": {
      "elected_office_id": {
        "type": "string",
        "minLength": 1,
        "maxLength": 128,
        "description": "Opaque gp-api ElectedOffice.id; passed through to the callback. Not used during research."
      },
      "state": {
        "type": "string",
        "pattern": "^[A-Z]{2}$",
        "description": "Two-letter state code (e.g. MN)."
      },
      "city": {
        "type": "string",
        "minLength": 1,
        "maxLength": 100,
        "description": "Full city name (e.g. Burnsville)."
      },
      "office": {
        "type": "string",
        "minLength": 1,
        "maxLength": 100,
        "description": "Governing body name (e.g. City Council)."
      }
    }
  },
  "output_schema": {
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "Briefing",
    "type": "object",
    "required": [
      "id",
      "slug",
      "meetingId",
      "title",
      "meetingDate",
      "status",
      "readingTimeMinutes",
      "generatedAt",
      "meeting",
      "executiveSummary",
      "agenda",
      "actionItems"
    ],
    "additionalProperties": false,
    "properties": {
      "id": { "type": "string" },
      "slug": { "type": "string" },
      "meetingId": { "type": "string" },
      "title": { "type": "string" },
      "meetingDate": { "type": "string" },
      "status": {
        "type": "string",
        "enum": ["briefing_ready", "awaiting_agenda", "generating", "failed"]
      },
      "readingTimeMinutes": { "type": "number" },
      "generatedAt": { "type": "string" },
      "meeting": {
        "type": "object",
        "required": ["id", "name", "body", "type", "scheduledAt", "location"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "body": { "type": "string" },
          "type": {
            "type": "string",
            "enum": ["city_council", "planning_board", "town_hall"]
          },
          "scheduledAt": { "type": "string" },
          "location": { "type": "string" }
        }
      },
      "executiveSummary": { "type": "string" },
      "agenda": {
        "type": "array",
        "items": {
          "type": "object",
          "required": ["id", "title", "kind", "hasBriefing"],
          "additionalProperties": false,
          "properties": {
            "id": { "type": "string" },
            "title": { "type": "string" },
            "kind": {
              "type": "string",
              "enum": [
                "procedural",
                "consent",
                "public_input",
                "action",
                "informational"
              ]
            },
            "hasBriefing": { "type": "boolean" },
            "whatToExpect": { "type": "string" }
          }
        }
      },
      "actionItems": {
        "type": "array",
        "items": {
          "type": "object",
          "required": [
            "id",
            "title",
            "overview",
            "constituentSentiment",
            "recentNews",
            "budgetImpact",
            "talkingPoints",
            "sources"
          ],
          "additionalProperties": false,
          "properties": {
            "id": { "type": "string" },
            "title": { "type": "string" },
            "overview": { "type": "string" },
            "constituentSentiment": {
              "oneOf": [
                {
                  "type": "object",
                  "required": ["summary", "sources"],
                  "additionalProperties": false,
                  "properties": {
                    "summary": { "type": "string" },
                    "detail": { "type": "string" },
                    "sources": {
                      "type": "array",
                      "items": { "type": "string" }
                    }
                  }
                },
                { "type": "null" }
              ]
            },
            "recentNews": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["title", "outlet", "url"],
                "additionalProperties": false,
                "properties": {
                  "title": { "type": "string" },
                  "outlet": { "type": "string" },
                  "url": { "type": "string" }
                }
              }
            },
            "budgetImpact": {
              "oneOf": [
                {
                  "type": "object",
                  "required": ["summary", "sources"],
                  "additionalProperties": false,
                  "properties": {
                    "summary": { "type": "string" },
                    "sources": {
                      "type": "array",
                      "items": { "type": "string" }
                    }
                  }
                },
                { "type": "null" }
              ]
            },
            "talkingPoints": {
              "type": "array",
              "items": { "type": "string" }
            },
            "sources": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["id", "label", "kind", "iconInitial", "url"],
                "additionalProperties": false,
                "properties": {
                  "id": { "type": "string" },
                  "label": { "type": "string" },
                  "kind": {
                    "type": "string",
                    "enum": ["internal", "official", "news", "community"]
                  },
                  "iconInitial": { "type": "string" },
                  "url": { "type": ["string", "null"] }
                }
              }
            }
          }
        }
      }
    }
  }
}
