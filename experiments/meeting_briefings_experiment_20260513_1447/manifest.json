{
  "$schema": "../_schema/manifest.schema.json",
  "id": "meeting_briefings_experiment_20260513_1447",
  "version": 1,
  "model": "sonnet",
  "max_turns": 100,
  "timeout_seconds": 3000,
  "scope": {
    "allowed_tables": [
      "goodparty_data_catalog.dbt.int__l2_nationwide_uniform_w_haystaq",
      "goodparty_data_catalog.sandbox.haystaq_data_dictionary"
    ],
    "max_rows": 1000
  },
  "input_schema": {
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "MeetingBriefingInput",
    "type": "object",
    "additionalProperties": false,
    "required": ["state", "city", "l2DistrictType", "l2DistrictName", "officialName", "meetingDate", "agendaPacketUrl"],
    "properties": {
      "state": {
        "type": "string",
        "pattern": "^[A-Z]{2}$",
        "description": "2-letter state code (e.g. NC)."
      },
      "city": {
        "type": "string",
        "minLength": 1,
        "description": "Full city name (e.g. Fayetteville)."
      },
      "l2DistrictType": {
        "type": "string",
        "minLength": 1,
        "description": "L2 voter file column name for district (e.g. City_Ward)."
      },
      "l2DistrictName": {
        "type": "string",
        "minLength": 1,
        "description": "L2 district value to match (e.g. FAYETTEVILLE CITY WARD 2)."
      },
      "officialName": {
        "type": "string",
        "minLength": 1,
        "description": "Full name of the elected official receiving the briefing."
      },
      "meetingDate": {
        "type": "string",
        "format": "date",
        "description": "Date of the council meeting (YYYY-MM-DD)."
      },
      "agendaPacketUrl": {
        "type": "string",
        "pattern": "^https?://",
        "description": "URL to the agenda packet PDF for the upcoming meeting."
      }
    }
  },
  "output_schema": {
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "MeetingBriefingOutput",
    "type": "object",
    "additionalProperties": false,
    "required": ["experiment_id", "generated_at", "official_name", "meeting_date", "estimated_read_minutes", "priority_items", "non_priority_items", "claims", "sources"],
    "properties": {
      "experiment_id": {
        "type": "string",
        "minLength": 1,
        "description": "Experiment id, echoed from PARAMS."
      },
      "generated_at": {
        "type": "string",
        "format": "date-time",
        "description": "ISO 8601 timestamp when the briefing was generated."
      },
      "official_name": {
        "type": "string",
        "minLength": 1,
        "description": "Name of the elected official."
      },
      "meeting_date": {
        "type": "string",
        "format": "date",
        "description": "Date of the council meeting."
      },
      "estimated_read_minutes": {
        "type": "integer",
        "minimum": 1,
        "description": "Estimated total read time in minutes."
      },
      "priority_items": {
        "type": "array",
        "minItems": 1,
        "maxItems": 3,
        "description": "Up to 3 priority agenda items, each with full briefing sections.",
        "items": {
          "type": "object",
          "additionalProperties": false,
          "required": ["item_number", "title", "requires_vote", "overview", "key_observations", "sources"],
          "properties": {
            "item_number": {
              "type": "integer",
              "minimum": 1,
              "description": "Agenda item number."
            },
            "title": {
              "type": "string",
              "minLength": 1,
              "description": "Agenda item title, copied exactly from the agenda packet."
            },
            "requires_vote": {
              "type": "boolean",
              "description": "True if this item requires a council vote."
            },
            "overview": {
              "type": "string",
              "minLength": 1,
              "description": "What is actually at stake for this item."
            },
            "constituent_sentiment": {
              "type": ["object", "null"],
              "additionalProperties": false,
              "description": "Haystaq-modeled constituent sentiment. Null if no relevant score exists.",
              "required": ["haystaq_column", "support_pct", "oppose_pct", "district_note", "disclosure"],
              "properties": {
                "haystaq_column": {
                  "type": "string",
                  "pattern": "^hs_[a-z0-9_]+$",
                  "description": "Haystaq column used for this sentiment estimate."
                },
                "support_pct": {
                  "type": ["number", "null"],
                  "minimum": 0,
                  "maximum": 100,
                  "description": "Modeled support percentage (0-100). Null if unavailable."
                },
                "oppose_pct": {
                  "type": ["number", "null"],
                  "minimum": 0,
                  "maximum": 100,
                  "description": "Modeled opposition percentage (0-100). Null if unavailable."
                },
                "district_note": {
                  "type": ["string", "null"],
                  "description": "District-level specificity note if available."
                },
                "disclosure": {
                  "type": "string",
                  "minLength": 1,
                  "description": "Required: note that figures are modeled estimates, not survey results."
                }
              }
            },
            "recent_news": {
              "type": ["array", "null"],
              "maxItems": 3,
              "description": "Up to 3 recent headlines. Null if no recent local coverage exists.",
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": ["headline", "publication", "article_type", "publication_date", "url"],
                "properties": {
                  "headline": {
                    "type": "string",
                    "minLength": 1
                  },
                  "publication": {
                    "type": "string",
                    "minLength": 1
                  },
                  "article_type": {
                    "type": "string",
                    "enum": ["reporting", "opinion", "editorial"]
                  },
                  "publication_date": {
                    "type": "string",
                    "format": "date"
                  },
                  "url": {
                    "type": "string",
                    "pattern": "^https?://"
                  }
                }
              }
            },
            "budget_impact": {
              "type": ["object", "null"],
              "additionalProperties": false,
              "description": "Budget impact. Null if no figures are available in source documents.",
              "required": ["total_cost", "per_constituent"],
              "properties": {
                "total_cost": {
                  "type": "string",
                  "minLength": 1,
                  "description": "Total cost copied exactly from source (one-time and/or recurring)."
                },
                "per_constituent": {
                  "type": ["string", "null"],
                  "description": "Per-constituent translation at the local levy level."
                }
              }
            },
            "key_observations": {
              "type": "array",
              "minItems": 1,
              "maxItems": 5,
              "description": "Synthesized observations for the official. Each is one or two sentences.",
              "items": {
                "type": "string",
                "minLength": 1
              }
            },
            "sources": {
              "type": "array",
              "minItems": 1,
              "description": "Bibliography entries for this priority item.",
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": ["source_name", "url", "source_type", "date_accessed"],
                "properties": {
                  "source_name": {
                    "type": "string",
                    "minLength": 1
                  },
                  "url": {
                    "type": "string",
                    "pattern": "^https?://"
                  },
                  "source_type": {
                    "type": "string",
                    "enum": ["agenda_packet", "news", "campaign", "haystaq", "government_website"]
                  },
                  "date_accessed": {
                    "type": "string",
                    "format": "date"
                  },
                  "verbatim_extract": {
                    "type": ["string", "null"],
                    "description": "Verbatim supporting extract from the source."
                  },
                  "page_number": {
                    "type": ["integer", "null"],
                    "description": "Page number for PDF sources."
                  },
                  "section_heading": {
                    "type": ["string", "null"],
                    "description": "Section heading for agenda packet sources."
                  }
                }
              }
            }
          }
        }
      },
      "non_priority_items": {
        "type": "array",
        "minItems": 0,
        "description": "Non-priority agenda items: one sentence each.",
        "items": {
          "type": "object",
          "additionalProperties": false,
          "required": ["item_number", "title", "description"],
          "properties": {
            "item_number": {
              "type": "integer",
              "minimum": 1
            },
            "title": {
              "type": "string",
              "minLength": 1
            },
            "description": {
              "type": "string",
              "minLength": 1,
              "description": "One sentence describing what it is and what the official should expect."
            }
          }
        }
      },
      "claims": {
        "type": "array",
        "minItems": 1,
        "description": "Flat list of every factual claim in the briefing.",
        "items": {
          "type": "object",
          "additionalProperties": false,
          "required": ["claim_text", "claim_type", "claim_weight", "source_extracts", "source_ids", "source_type"],
          "properties": {
            "claim_text": {
              "type": "string",
              "minLength": 1,
              "description": "Verbatim text which appears in the briefing."
            },
            "claim_type": {
              "type": "string",
              "minLength": 1,
              "description": "E.g. budget number, constituent sentiment, meeting name, meeting date."
            },
            "claim_weight": {
              "type": "string",
              "enum": ["high", "medium", "low"]
            },
            "source_extracts": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string",
                "minLength": 1
              },
              "description": "Verbatim passages from cited sources."
            },
            "source_ids": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string",
                "minLength": 1
              },
              "description": "References to entries in sources array."
            },
            "source_type": {
              "type": "string",
              "minLength": 1,
              "description": "E.g. Official budget, Agenda PDF, Staff report, Haystaq constituent data, News, campaign website."
            }
          }
        }
      },
      "sources": {
        "type": "array",
        "minItems": 1,
        "description": "Full bibliography. Each entry includes source name, URL, type, date accessed, and location metadata.",
        "items": {
          "type": "object",
          "additionalProperties": false,
          "required": ["id", "source_name", "url", "source_type", "date_accessed"],
          "properties": {
            "id": {
              "type": "string",
              "minLength": 1,
              "description": "Unique identifier for cross-referencing from claims."
            },
            "source_name": {
              "type": "string",
              "minLength": 1
            },
            "url": {
              "type": "string",
              "pattern": "^https?://"
            },
            "source_type": {
              "type": "string",
              "enum": ["agenda_packet", "news", "campaign", "haystaq", "government_website"]
            },
            "date_accessed": {
              "type": "string",
              "format": "date"
            },
            "article_date": {
              "type": ["string", "null"],
              "format": "date",
              "description": "Publication date for news sources."
            },
            "article_type": {
              "type": ["string", "null"],
              "enum": ["reporting", "opinion", "editorial", null],
              "description": "Article type for news sources."
            },
            "page_numbers": {
              "type": ["array", "null"],
              "items": {
                "type": "integer",
                "minimum": 1
              },
              "description": "Page numbers for PDF sources."
            }
          }
        }
      },
      "disclosure": {
        "type": "string",
        "minLength": 1,
        "description": "Required disclosure that this briefing was AI-generated and may contain errors."
      }
    }
  }
}
