{
  "$schema": "../_schema/manifest.schema.json",
  "id": "meeting_briefings_experiment_20260513_1155",
  "version": 1,
  "model": "sonnet",
  "max_turns": 100,
  "timeout_seconds": 3000,
  "input_schema": {
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "MeetingBriefingInput",
    "type": "object",
    "additionalProperties": false,
    "required": [
      "state",
      "city",
      "l2DistrictType",
      "l2DistrictName",
      "officialName",
      "meetingDate",
      "agendaUrl"
    ],
    "properties": {
      "state": {
        "type": "string",
        "pattern": "^[A-Z]{2}$",
        "description": "2-letter state code (e.g. NC)."
      },
      "city": {
        "type": "string",
        "minLength": 1,
        "description": "Full city name (e.g. Fayetteville)."
      },
      "l2DistrictType": {
        "type": "string",
        "minLength": 1,
        "description": "L2 voter file column name for district (e.g. City_Ward)."
      },
      "l2DistrictName": {
        "type": "string",
        "minLength": 1,
        "description": "L2 district value to match (e.g. FAYETTEVILLE CITY WARD 2)."
      },
      "officialName": {
        "type": "string",
        "minLength": 1,
        "description": "Full name of the elected official being briefed."
      },
      "meetingDate": {
        "type": "string",
        "format": "date",
        "description": "Date of the meeting in ISO 8601 format (YYYY-MM-DD)."
      },
      "agendaUrl": {
        "type": "string",
        "format": "uri",
        "pattern": "^https?://",
        "description": "URL to the agenda PDF for the upcoming meeting."
      },
      "campaignUrl": {
        "type": "string",
        "format": "uri",
        "pattern": "^https?://",
        "description": "URL to the elected official's campaign website. Optional — used as context for the official's stated positions."
      }
    }
  },
  "output_schema": {
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "MeetingBriefingOutput",
    "type": "object",
    "additionalProperties": false,
    "required": ["briefing", "claims", "sources", "generated_at"],
    "properties": {
      "generated_at": {
        "type": "string",
        "format": "date-time",
        "description": "ISO 8601 timestamp when the artifact was assembled."
      },
      "briefing": {
        "type": "object",
        "additionalProperties": false,
        "required": ["official_name", "estimated_read_time_minutes", "agenda", "executive_summary", "priority_items", "non_priority_items", "required_disclosure"],
        "description": "Structured briefing content. One object per priority item; non-priority items as flat array.",
        "properties": {
          "official_name": {
            "type": "string",
            "minLength": 1
          },
          "estimated_read_time_minutes": {
            "type": "integer",
            "minimum": 1,
            "maximum": 60
          },
          "agenda": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["item_number", "title", "is_priority"],
              "properties": {
                "item_number": {
                  "type": "integer",
                  "minimum": 1
                },
                "title": {
                  "type": "string",
                  "minLength": 1
                },
                "is_priority": {
                  "type": "boolean"
                }
              }
            }
          },
          "executive_summary": {
            "type": "array",
            "minItems": 1,
            "maxItems": 3,
            "description": "One entry per priority item — what it requires (vote / no vote) and what's at stake.",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["item_title", "requires_vote", "summary"],
              "properties": {
                "item_title": {
                  "type": "string",
                  "minLength": 1
                },
                "requires_vote": {
                  "type": "boolean"
                },
                "summary": {
                  "type": "string",
                  "minLength": 1
                }
              }
            }
          },
          "priority_items": {
            "type": "array",
            "minItems": 1,
            "maxItems": 3,
            "description": "Full depth sections for each priority agenda item.",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["title", "overview", "key_observations"],
              "properties": {
                "title": {
                  "type": "string",
                  "minLength": 1
                },
                "overview": {
                  "type": "string",
                  "minLength": 1,
                  "description": "What is actually at stake — not just what the item is."
                },
                "constituent_sentiment": {
                  "type": ["object", "null"],
                  "description": "Haystaq modeled sentiment. Null if no relevant score exists.",
                  "additionalProperties": false,
                  "required": ["support_pct", "oppose_pct", "summary"],
                  "properties": {
                    "support_pct": {
                      "type": "number",
                      "minimum": 0,
                      "maximum": 100
                    },
                    "oppose_pct": {
                      "type": "number",
                      "minimum": 0,
                      "maximum": 100
                    },
                    "summary": {
                      "type": "string",
                      "minLength": 1
                    }
                  }
                },
                "recent_news": {
                  "type": ["array", "null"],
                  "description": "Up to 3 recent headlines. Null if no recent local coverage exists.",
                  "maxItems": 3,
                  "items": {
                    "type": "object",
                    "additionalProperties": false,
                    "required": ["headline", "publication", "article_type", "publication_date", "source_id"],
                    "properties": {
                      "headline": {
                        "type": "string",
                        "minLength": 1
                      },
                      "publication": {
                        "type": "string",
                        "minLength": 1
                      },
                      "article_type": {
                        "type": "string",
                        "enum": ["reporting", "opinion", "editorial"]
                      },
                      "publication_date": {
                        "type": ["string", "null"],
                        "format": "date"
                      },
                      "source_id": {
                        "type": "string",
                        "minLength": 1,
                        "description": "Reference to an entry in the sources array."
                      }
                    }
                  }
                },
                "budget_impact": {
                  "type": ["object", "null"],
                  "description": "Budget figures extracted from source exactly. Null if no figures are available.",
                  "additionalProperties": false,
                  "required": ["summary"],
                  "properties": {
                    "total_cost_one_time": {
                      "type": ["string", "null"],
                      "description": "Verbatim dollar amount from source for one-time cost."
                    },
                    "total_cost_recurring": {
                      "type": ["string", "null"],
                      "description": "Verbatim dollar amount from source for recurring cost."
                    },
                    "per_constituent_translation": {
                      "type": ["string", "null"],
                      "description": "Per-constituent cost at local levy level."
                    },
                    "summary": {
                      "type": "string",
                      "minLength": 1
                    }
                  }
                },
                "key_observations": {
                  "type": "array",
                  "minItems": 1,
                  "maxItems": 5,
                  "description": "Synthesized observations for the official. Up to five bullets, one-two sentences each.",
                  "items": {
                    "type": "string",
                    "minLength": 1
                  }
                }
              }
            }
          },
          "required_disclosure": {
            "type": "string",
            "minLength": 1,
            "description": "Mandatory AI assistance disclosure. Must appear verbatim in every briefing."
          },
          "non_priority_items": {
            "type": "array",
            "description": "One sentence per non-priority item describing what it is and what the official should expect.",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["title", "description"],
              "properties": {
                "title": {
                  "type": "string",
                  "minLength": 1
                },
                "description": {
                  "type": "string",
                  "minLength": 1
                }
              }
            }
          }
        }
      },
      "claims": {
        "type": "array",
        "minItems": 1,
        "description": "Flat list of every factual claim in the briefing.",
        "items": {
          "type": "object",
          "additionalProperties": false,
          "required": ["claim_text", "claim_type", "claim_weight", "source_extracts", "source_ids", "source_type"],
          "properties": {
            "claim_text": {
              "type": "string",
              "minLength": 1,
              "description": "Verbatim text which appears in the briefing."
            },
            "claim_type": {
              "type": "string",
              "minLength": 1,
              "description": "E.g. budget number, constituent sentiment, meeting name, meeting date."
            },
            "claim_weight": {
              "type": "string",
              "enum": ["high", "medium", "low"]
            },
            "source_extracts": {
              "type": "array",
              "minItems": 1,
              "description": "Verbatim passages from the cited sources.",
              "items": {
                "type": "string",
                "minLength": 1
              }
            },
            "source_ids": {
              "type": "array",
              "minItems": 1,
              "description": "References to entries in the sources array.",
              "items": {
                "type": "string",
                "minLength": 1
              }
            },
            "source_type": {
              "type": "string",
              "minLength": 1,
              "description": "E.g. Agenda PDF, Staff report, Haystaq constituent data, News, Campaign website, Government website."
            }
          }
        }
      },
      "sources": {
        "type": "array",
        "minItems": 1,
        "description": "Full bibliography. Each entry is one source document.",
        "items": {
          "type": "object",
          "additionalProperties": false,
          "required": ["id", "name", "url", "type", "date_accessed"],
          "properties": {
            "id": {
              "type": "string",
              "minLength": 1,
              "description": "Stable identifier referenced by claim source_ids."
            },
            "name": {
              "type": "string",
              "minLength": 1
            },
            "url": {
              "type": "string",
              "format": "uri",
              "pattern": "^https?://"
            },
            "type": {
              "type": "string",
              "enum": ["agenda_packet", "news", "campaign", "haystaq", "government_website"]
            },
            "date_accessed": {
              "type": "string",
              "format": "date-time"
            },
            "page_number": {
              "type": ["integer", "null"],
              "description": "For agenda packet sources."
            },
            "section_heading": {
              "type": ["string", "null"],
              "description": "For agenda packet sources."
            },
            "article_date": {
              "type": ["string", "null"],
              "format": "date",
              "description": "For news sources."
            }
          }
        }
      }
    }
  },
  "scope": {
    "allowed_tables": [
      "goodparty_data_catalog.dbt.int__l2_nationwide_uniform_w_haystaq",
      "goodparty_data_catalog.sandbox.haystaq_data_dictionary"
    ],
    "max_rows": 1000
  }
}
