{
  "$schema": "../_schema/manifest.schema.json",
  "id": "meeting_schedule",
  "version": 1,
  "model": "sonnet",
  "max_turns": 30,
  "timeout_seconds": 600,
  "input_schema": {
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "MeetingScheduleInput",
    "type": "object",
    "additionalProperties": false,
    "required": ["state", "city", "office"],
    "properties": {
      "elected_office_id": {
        "type": "string",
        "minLength": 1,
        "maxLength": 128,
        "description": "Opaque gp-api ElectedOffice.id; passed through to the callback. Not used during research."
      },
      "state": {
        "type": "string",
        "pattern": "^[A-Z]{2}$",
        "description": "Two-letter state code (e.g. MN)."
      },
      "city": {
        "type": "string",
        "minLength": 1,
        "maxLength": 100,
        "description": "Full city name (e.g. Burnsville)."
      },
      "office": {
        "type": "string",
        "minLength": 1,
        "maxLength": 100,
        "description": "Governing body name (e.g. City Council)."
      }
    }
  },
  "output_schema": {
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "MeetingSchedule",
    "type": "object",
    "additionalProperties": false,
    "required": [
      "generated_at",
      "status",
      "rrule",
      "human",
      "time",
      "timezone",
      "duration_minutes",
      "sources"
    ],
    "properties": {
      "generated_at": {
        "type": "string",
        "format": "date-time"
      },
      "status": {
        "type": "string",
        "enum": ["found", "not_found"]
      },
      "rrule": {
        "type": "string",
        "maxLength": 500,
        "description": "iCalendar RFC 5545 RRULE string. MUST NOT contain DTSTART. Empty when status=not_found."
      },
      "human": {
        "type": "string",
        "maxLength": 500,
        "description": "One-sentence English description of the recurrence; must match the RRULE semantically."
      },
      "time": {
        "type": "string",
        "maxLength": 5,
        "description": "24-hour HH:MM in local time. Empty when status=not_found."
      },
      "timezone": {
        "type": "string",
        "maxLength": 64,
        "description": "IANA timezone name (e.g. America/Denver). Empty when status=not_found."
      },
      "duration_minutes": {
        "type": "integer",
        "minimum": 0,
        "maximum": 1440,
        "description": "Typical meeting length in minutes. 0 when status=not_found."
      },
      "sources": {
        "type": "array",
        "maxItems": 20,
        "items": {
          "type": "object",
          "additionalProperties": false,
          "required": ["url", "note"],
          "properties": {
            "url": {
              "type": "string",
              "pattern": "^https?://",
              "maxLength": 2048
            },
            "note": {
              "type": "string",
              "minLength": 1,
              "maxLength": 500
            }
          }
        }
      }
    },
    "oneOf": [
      {
        "properties": {
          "status": { "const": "found" },
          "rrule": {
            "minLength": 1,
            "pattern": "^FREQ=(DAILY|WEEKLY|MONTHLY|YEARLY)"
          },
          "human": { "minLength": 1 },
          "time": { "pattern": "^([01][0-9]|2[0-3]):[0-5][0-9]$" },
          "timezone": { "pattern": "^[A-Za-z]+(/[A-Za-z_]+)+$" },
          "duration_minutes": { "minimum": 15 },
          "sources": { "minItems": 1 }
        }
      },
      {
        "properties": {
          "status": { "const": "not_found" },
          "rrule": { "maxLength": 0 },
          "human": { "maxLength": 0 },
          "time": { "maxLength": 0 },
          "timezone": { "maxLength": 0 },
          "duration_minutes": { "maximum": 0 }
        }
      }
    ]
  }
}
