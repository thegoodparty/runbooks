# Non-sensitive configuration for runbooks
# AI agents may read this file to resolve $VARIABLES in books
# Never put API keys, tokens, passwords, or credentials here

# PROJECT_ROOT= example ~/work
# AWS_REGION= example us-west-2
# AWS_PROFILE= example work-profile or gp-debug-only
# GRAFANA_TOKEN= example glsa_xxxxxxxxxxxx (from Grafana UI → Administration → Service accounts)

# Used by the ClickUp books — non-secret IDs and paths only.
# CLICKUP_TEAM_ID= example 90132012119 (find via `uv run clickup_api.py GET team`)
# CLICKUP_LIST_ID= example 901324567890 (target List ID where Epics + tasks are created)
# CLICKUP_DRAFTS_DIR= example $HOME/.claude/drafts/clickup (per-Epic draft directories live here)
# CLICKUP_PLANS_DIR= example $HOME/.claude/plans (Epic-level technical plans saved here after creation)
# CLICKUP_DESIGNS_DIR= example $HOME/.claude/designs/clickup (blessed tech design docs saved here by prd-to-tech-design.md)
# CLICKUP_REPOS_DIR= example $HOME/.claude/repos (public repos cloned here for analysis)
# CLICKUP_EDITOR= example code (command used to open draft files for review; e.g., code, cursor, subl)
