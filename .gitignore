.env
.DS_Store
node_modules/
__pycache__/
.venv/

# Scratch reference materials for in-progress runbooks (prompt components,
# example briefings, notes). Compiled outputs land in books/ as tracked files;
# the scratch dir stays local.
.reference_docs/

# Local agent run outputs (params, conversation transcripts, downloads, logs).
# These can contain absolute paths, candidate PII, and full LLM transcripts.
outputs/

# Comparison stash for runbook→experiment translation iterations
# (see books/convert-runbook-to-experiment.md and experiments/CLAUDE.md).
experiments/.collin_reference/

# Generated by scripts/python/publish_experiments.py — never commit.
# The publisher writes a fresh index.json to S3 on every publish; the
# committed file would silently strip hand-edited fields and mislead readers.
experiments/index.json
