# Secrets and credentials for script execution
# AI agents MUST NOT read this file
# Only used at runtime by scripts

# API_KEY=
# DATABASE_URL=

# CIRCLE_API_KEY= example from https://app.circle.so/admin/developer-tokens (Admin API v2 Bearer token)

# DATABRICKS_API_KEY= Databricks personal access token
# DATABRICKS_SERVER_HOSTNAME= Databricks SQL warehouse hostname
# DATABRICKS_HTTP_PATH= Databricks SQL warehouse HTTP path

# ANTHROPIC_API_KEY= Anthropic API key (used by enrich_michigan_leads.py)
# GOOGLE_CIVIC_API_KEY= (optional) Google Civic Information API key for district verification
