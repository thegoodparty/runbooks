# Secrets and credentials for script execution
# AI agents MUST NOT read this file
# Only used at runtime by scripts

# API_KEY=
# DATABASE_URL=

# CIRCLE_API_KEY= example from https://app.circle.so/admin/developer-tokens (Admin API v2 Bearer token)

# CLICKUP_API_KEY= example pk_xxx (ClickUp → Settings → Apps → API Token; sent as raw value, no Bearer prefix)

# Databricks credentials — required by scripts/python/databricks_query.py
# Naming matches the Databricks SDK convention; same names are used in ~/Research/.env.
# DATABRICKS_HOST= example adb-xxxx.azuredatabricks.net
# DATABRICKS_HTTP_PATH= example /sql/1.0/warehouses/xxxx
# DATABRICKS_TOKEN= example dapi_xxxx
